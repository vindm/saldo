# ──────────────────────────────────────────────────────────────
# DATA & SECRETS — never commit. A practice's real client data and
# credentials live OUTSIDE this repo, referenced via config/instance.yaml.
# ──────────────────────────────────────────────────────────────

# Real practice data directories (clients, statements, state, history)
/data/
/data-*/
instances/*/data/
**/state/
**/history.jsonl
**/mental_model.md
clients_index.json          # real roster (the example one is committed explicitly)
!instances/example/**/clients_index.json

# Ship the SYNTHETIC example instance so the demo runs from a fresh clone.
# State JSON is the source of truth; committed for the EXAMPLE ONLY. The generic
# rules below still apply, so generated *.html, *.bak_*, __pycache__ under the
# example stay ignored (dashboards are regenerated by engine/generate.py).
!instances/example/data/
!instances/example/data/**

# Local per-machine config pointer — points at a real data.dir; never commit.
config/instance.yaml

# Secrets & credentials
**/секреты/
**/secrets/
*.session
*_api.json
*.key
*.pem
.env
.env.*

# Generated dashboards (may contain client data when run on a real instance)
*.html
!docs/**/*.html

# Backups, caches, OS noise
*.bak_*
*.bak[0-9]*
*.before_rerun_*
__pycache__/
*.pyc
.idea/
.DS_Store
.obsidian/

# Office binaries (often carry client-specific content)
*.docx
*.xlsx
*.xls
*.pdf
*.zip
*.doc

engine/_LINT.json

# Local full-system snapshots (engine/snapshot.py output) — contain real state
# when run on a real instance; never commit. (Archive/dead_modules/ stays tracked.)
Archive/snapshots/
*.tar.gz